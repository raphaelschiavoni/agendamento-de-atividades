# development (local) ou production (EasyPanel/VPS)
NODE_ENV=development

# Conexão do PostgreSQL (Neon ou o banco da sua VPS)
DATABASE_URL=postgres://user:password@host/dbname?sslmode=require

# Segredo dos cookies de sessão — gere uma string aleatória longa
SESSION_SECRET=change-me-to-a-random-string

PORT=4000

# Em desenvolvimento, origem do front (Vite). Em produção (mesmo container),
# não é necessário pois o front é servido pela mesma origem.
CLIENT_ORIGIN=http://localhost:5173

# Integrações (mock/stub por enquanto)
PAYMENT_PROVIDER=mock
NOTIFICATION_PROVIDER=console
MOCK_PIX_AUTO_APPROVE_MS=

# Pasta de uploads de fotos. Em produção, aponte para um volume persistente.
UPLOADS_DIR=./uploads

# (Opcional) Caminho do build do front. Em produção é derivado automaticamente
# (client/dist ao lado do server); só defina se mudar a estrutura de pastas.
# STATIC_DIR=
